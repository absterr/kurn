{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch server.ts",
    "start": "bun server.ts",
    "db:gen": "bun --env-file .env --env-file .env.local kysely-codegen --dialect postgres --camel-case --out-file db/types.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "kysely-codegen": "^0.20.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.29.2",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}
