{
  "name": "db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "db:setup": "bun scripts/setup-triggers.ts",
    "db:clear": "bun scripts/clear-triggers.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate && bun db:setup",
    "db:push": "bunx drizzle-kit push && bun db:setup",
    "db:drop": "bunx drizzle-kit drop && bunx drizzle-kit migrate",
    "db:reset": "bun db:drop && bun db:clear"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2"
  }
}
